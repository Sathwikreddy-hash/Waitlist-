{
  "entities": {
    "WaitlistEntry": {
      "title": "Waitlist Entry",
      "description": "Details of users who joined the EV charging waitlist",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the user" },
        "phone": { "type": "string", "description": "Phone number of the user" },
        "email": { "type": "string", "description": "Email address of the user" },
        "usePublicCharging": { 
          "type": "string", 
          "enum": ["Yes", "Sometimes", "Never"],
          "description": "Whether the user uses public charging"
        },
        "biggestIssue": { 
          "type": "string", 
          "enum": ["Charger not working", "Busy", "Hard to find", "Don’t use"],
          "description": "The biggest issue user faces with public charging"
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the entry was created" }
      },
      "required": ["email", "usePublicCharging", "biggestIssue", "createdAt"]
    },
    "Visit": {
      "title": "Page Visit",
      "description": "Records of page visits for analytics",
      "type": "object",
      "properties": {
        "path": { "type": "string", "description": "Page path visited" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of visit" },
        "userAgent": { "type": "string", "description": "User agent of the visitor" }
      },
      "required": ["path", "timestamp"]
    }
  },
  "firestore": {
    "/waitlist/{entryId}": {
      "schema": "WaitlistEntry",
      "description": "Collection of waitlist registrations"
    },
    "/analytics_visits/{visitId}": {
      "schema": "Visit",
      "description": "Collection of page visit events"
    }
  }
}
