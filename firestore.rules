rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /waitlist/{entryId} {
      allow create: if request.resource.data.email is string &&
                    request.resource.data.usePublicCharging is string &&
                    request.resource.data.biggestIssue is string &&
                    request.resource.data.createdAt == request.time &&
                    (!('phone' in request.resource.data) || request.resource.data.phone is string);
      allow read: if isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /analytics_visits/{visitId} {
      allow create: if request.resource.data.path is string &&
                    request.resource.data.timestamp == request.time;
      allow read: if isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
